# Django secret key — generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# Set to "True" only for local development
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Shared secret between Docker container and host relay — generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_AUTH_TOKEN=change-me-to-a-random-token
